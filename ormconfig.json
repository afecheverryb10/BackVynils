{
    "type": "postgres",
    "url": "${DATABASE_URL}",
    "port": "${DB_PORT:5432}",
    "username": "${DB_USERNAME:postgres}",
    "password": "${DB_PASSWORD:postgres}",
    "database": "${DB_NAME:vinyls}",
    "synchronize": false,
    "logging": false,
    "ssl": "${DB_SSL:true}",
    "extra": {
        "ssl": {
            "rejectUnauthorized": false
        }
    },
    "entities": [
        "src/**/*entity.ts"
    ],
    "migrations": [
        "src/migration/**/*.ts"
    ],
    "subscribers": [
        "src/subscriber/**/*.ts"
    ],
    "cli": {
        "entitiesDir": "src/",
        "migrationsDir": "src/migration",
        "subscribersDir": "src/subscriber"
    }
}